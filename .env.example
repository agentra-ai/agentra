# Database
POSTGRES_DB=agentra
POSTGRES_USER=agentra
POSTGRES_PASSWORD=agentra
POSTGRES_PORT=5432
DATABASE_URL=postgres://agentra:agentra@localhost:5432/agentra?sslmode=disable

# Server
PORT=8080
SERVER_INTERNAL_PORT=8080
SERVER_HEALTHCHECK_URL=http://localhost:8080/health
JWT_SECRET=change-me-in-production

# Local loopback callback used by `agentra login` on the machine running the CLI
AGENTRA_LOCAL_BIND_HOST=127.0.0.1
AGENTRA_CALLBACK_HOST=localhost

# Public service URLs used by the CLI and web app
AGENTRA_SERVER_URL=ws://server.agentra.orb.local/ws
AGENTRA_APP_URL=http://web.agentra.orb.local
AGENTRA_DAEMON_CONFIG=
AGENTRA_WORKSPACE_ID=
AGENTRA_DAEMON_ID=
AGENTRA_DAEMON_DEVICE_NAME=
AGENTRA_DAEMON_POLL_INTERVAL=3s
AGENTRA_DAEMON_HEARTBEAT_INTERVAL=15s
AGENTRA_CODEX_PATH=codex
AGENTRA_CODEX_MODEL=
AGENTRA_CODEX_WORKDIR=
AGENTRA_CODEX_TIMEOUT=20m

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@agentra.ai

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://web.agentra.orb.local/auth/callback

# S3 / CloudFront
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=agentra/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=

# MinIO (local S3-compatible object storage)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=agentra-uploads

# Frontend
FRONTEND_PORT=3000
WEB_INTERNAL_PORT=3000
WEB_HOSTNAME=0.0.0.0

# Public frontend and API origins
FRONTEND_ORIGIN=http://web.agentra.orb.local
NEXT_PUBLIC_SITE_URL=http://web.agentra.orb.local
NEXT_PUBLIC_API_URL=http://server.agentra.orb.local
NEXT_PUBLIC_WS_URL=ws://server.agentra.orb.local/ws

# Hosts accepted for the browser -> local CLI callback handoff
NEXT_PUBLIC_CLI_CALLBACK_HOSTS=localhost,127.0.0.1

# Remote API (optional) — set to proxy local frontend to a remote backend
# Leave empty to use NEXT_PUBLIC_API_URL
REMOTE_API_URL=
